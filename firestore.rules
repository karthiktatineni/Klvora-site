rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Admin Check - Now explicitly hardened for admin@klvora.in
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email.lower() == "admin@klvora.in" ||
        request.auth.token.email.lower().endsWith("@klvora.in") ||
        request.auth.token.admin == true
      );
    }

    // Orders Collection: Hardened Security
    match /orders/{orderId} {
      // Public can create orders (for guest checkout support)
      allow create: if true;
      
      // READ: Master Admin access OR Owner-only access
      allow read: if isAdmin() || (
        request.auth != null && (
          // Matches UID at root or in customer object
          request.auth.uid == resource.data.customerId ||
          (resource.data.customer != null && request.auth.uid == resource.data.customer.customerId) ||
          // Matches Email at root or in customer object
          request.auth.token.email == resource.data.email ||
          (resource.data.customer != null && request.auth.token.email == resource.data.customer.email)
        )
      );
      
      // WRITE: Only admins can modify status or delete
      allow update, delete: if isAdmin();
    }
    
    // Inventory: Public Read, Admin-only Update
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // User Profiles: Personal Access Only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
