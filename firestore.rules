rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // TEMPORARY FULL ACCESS FOR DEBUGGING
    match /orders/{orderId} {
      allow read, write: if true;
    }
    
    match /products/{productId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /messages/{messageId} {
      allow read, write: if true;
    }
  }
}
